<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no">
<meta name="referrer" content="no-referrer">
<title>OneSports // Live Player</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/shaka-player@5.1.8/dist/controls.css">
<style>
/* Base Styles */
*{margin:0;padding:0;box-sizing:border-box}
html,body{width:100%;height:100%;background:#000;overflow:hidden;font-family:'Segoe UI',Roboto,sans-serif;-webkit-user-select:none;user-select:none}
.shaka-video-container{position:fixed;inset:0;background:#000;display:flex;align-items:center;justify-content:center}
video{width:100%;height:100%;object-fit:contain;background:#000}

/* Hide Default Shaka Spinner */
.shaka-spinner-container,.shaka-spinner,.shaka-spinner-svg{display:none!important}
.shaka-controls-container button{color:#fff!important}

/* Custom Loading Spinner */
#loader{position:absolute;inset:0;background:rgba(0,0,0,.6);display:flex;align-items:center;justify-content:center;z-index:9;opacity:0;pointer-events:none;transition:opacity .2s}
#loader.on{opacity:1}
.spin{width:40px;height:40px;border:4px solid rgba(255,255,255,.2);border-top-color:#e63946;border-radius:50%;animation:sp .8s linear infinite}
@keyframes sp{to{transform:rotate(360deg)}}

/* OneSports Text Watermark */
#wm{
  position:absolute;
  z-index:5;
  pointer-events:none;
  display:flex;
  align-items:center;
  opacity:0.65;
  filter:drop-shadow(0 2px 4px rgba(0,0,0,0.8));
  transition:opacity .25s, bottom .25s, right .25s;
  bottom: 20px;
  right: 20px;
}
.wm-text {
  font-family: 'Orbitron', 'Segoe UI', sans-serif;
  font-weight: 800;
  font-size: 18px;
  letter-spacing: 1px;
  white-space: nowrap;
  text-transform: uppercase;
}
.wm-text .one { color: #ffffff; }
.wm-text .sports { color: #e63946; }

/* Move watermark up when controls are active so they don't overlap */
.controls-visible #wm {
  bottom: 65px; 
}
</style>
</head>
<body>
<div class="shaka-video-container" id="pc">
  <!-- Video element -->
  <video id="v" autoplay playsinline muted preload="metadata"></video>
  
  <!-- Watermark -->
  <div id="wm">
    <div class="wm-text"><span class="one">One</span><span class="sports">Sports</span></div>
  </div>
  
  <!-- Loading Spinner -->
  <div id="loader"><div class="spin"></div></div>
</div>

<script src="https://cdn.jsdelivr.net/npm/shaka-player@5.1.8/dist/shaka-player.ui.min.js"></script>
<script>
/* =======================================================
   CHANGE YOUR M3U8 STREAM URL HERE 
======================================================= */
const STREAM_URL = "https://dash2.antik.sk/stream/nvidia_ct_sport/playlist_cenc.mpd";
/* ======================================================= */

document.addEventListener('DOMContentLoaded', async () => {
  shaka.polyfill.installAll();
  if (!shaka.Player.isBrowserSupported()) {
    console.error('Browser not supported!');
    return;
  }

  const videoEl = document.getElementById('v');
  const container = document.getElementById('pc');
  const loader = document.getElementById('loader');

  const player = new shaka.Player();
  await player.attach(videoEl);

  // Setup UI with Picture-in-Picture, Quality Selector, etc.
  const ui = new shaka.ui.Overlay(player, container, videoEl);
  ui.configure({
    controlPanelElements: [
      'play_pause', 'mute', 'volume', 'time_and_duration',
      'spacer', 'picture_in_picture', 'quality', 'fullscreen'
    ],
    seekBarColors: { base: 'rgba(255,255,255,0.3)', buffered: 'rgba(255,255,255,0.6)', played: '#e63946' },
    fadeDelay: 3,
    addBigPlayButton: true,
  });

  // Handle Loading Spinner
  player.addEventListener('buffering', (e) => {
    loader.classList.toggle('on', e.buffering);
  });

  // Shift watermark when controls show/hide
  const controlsContainer = container.querySelector('.shaka-controls-container');
  if (controlsContainer) {
    const observer = new MutationObserver(() => {
      container.classList.toggle('controls-visible', controlsContainer.getAttribute('shown') !== null);
    });
    observer.observe(controlsContainer, { attributes: true, attributeFilter: ['shown'] });
  }

  // Optimize for Live Streams (Adaptive resolutions, live edge tracking)
  player.configure({
    abr: {
      enabled: true, // Automatically switches resolutions
      defaultBandwidthEstimate: 3000000, 
    },
    streaming: {
      bufferingGoal: 10,
      rebufferingGoal: 2,
      bufferBehind: 15,
      lowLatencyMode: true, // Optimizes for live broadcasts
      jumpLargeGaps: true,
      retryParameters: {
        maxAttempts: 5,
        baseDelay: 1000,
        timeout: 20000
      }
    }
  });

  loader.classList.add('on');
  try {
    // Load the stream
    await player.load(STREAM_URL);
    loader.classList.remove('on');
    
    // Attempt to seek to the absolute latest live edge
    if (player.isLive()) {
      videoEl.currentTime = player.seekRange().end;
    }

    try {
      await videoEl.play();
    } catch (e) {
      console.warn('Autoplay prevented by browser:', e);
    }
  } catch (e) {
    console.error('Error loading stream:', e);
    loader.classList.remove('on');
  }
});
</script>
</body>
</html>
